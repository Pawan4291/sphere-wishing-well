{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://sphere.unicity.network https://unicity-sphere.github.io"
        }
      ]
    }
  ]
}
